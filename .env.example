# options_algo — Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file to git.

# ─── Polygon.io ────────────────────────────────────────────────────────────────
# Options Starter plan ($29/mo): options chains, IV, Greeks, snapshots
# Stocks Starter plan ($29/mo): real-time OHLCV, aggregates
POLYGON_API_KEY=your_polygon_api_key_here

# ─── Finnhub ───────────────────────────────────────────────────────────────────
# Free tier: earnings calendar, news, sentiment
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── Alpha Vantage ─────────────────────────────────────────────────────────────
# Free tier: backup quotes
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ─── Tradier ───────────────────────────────────────────────────────────────────
# Free with brokerage account: backup options data, real-time quotes
TRADIER_API_KEY=
TRADIER_ACCOUNT_ID=

# ─── Delivery ──────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=your_whatsapp_number_here

# ─── Universe ──────────────────────────────────────────────────────────────────
UNIVERSE_SIZE=SP100

# ─── Risk Parameters (override defaults in settings.py) ────────────────────────
# MAX_RISK_PER_TRADE_PCT=2.0
# MAX_POSITIONS=5
# PROFIT_TARGET_PCT=50
# STOP_LOSS_PCT=100

# ─── IV Thresholds ─────────────────────────────────────────────────────────────
# IV_HIGH_THRESHOLD=70
# IV_LOW_THRESHOLD=30

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

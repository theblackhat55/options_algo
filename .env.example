# options_algo — Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file to git.

# ─── Polygon.io ────────────────────────────────────────────────────────────────
# Options Starter plan ($29/mo): options chains, IV, Greeks, snapshots
# Stocks Starter plan ($29/mo): real-time OHLCV, aggregates
POLYGON_API_KEY=your_polygon_api_key_here

# ─── Finnhub ───────────────────────────────────────────────────────────────────
# Free tier: earnings calendar, news, sentiment
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── Alpha Vantage ─────────────────────────────────────────────────────────────
# Free tier: backup quotes
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ─── Tradier ───────────────────────────────────────────────────────────────────
# Free with brokerage account: backup options data, real-time quotes
TRADIER_API_KEY=
TRADIER_ACCOUNT_ID=

# ─── Delivery ──────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=your_whatsapp_number_here

# ─── Universe ──────────────────────────────────────────────────────────────────
UNIVERSE_SIZE=SP100

# ─── Risk Parameters (override defaults in settings.py) ────────────────────────
# MAX_RISK_PER_TRADE_PCT=2.0
# MAX_POSITIONS=5
# PROFIT_TARGET_PCT=50
# STOP_LOSS_PCT=100

# ─── IV Thresholds ─────────────────────────────────────────────────────────────
# IV_HIGH_THRESHOLD=70
# IV_LOW_THRESHOLD=30

# ─── V2: Regime / Directional-Balance / Snap-back (override defaults) ──────────
# Maximum % of picks that may share the same direction (BULLISH or BEARISH).
# At MAX_POSITIONS=5 this caps same-direction at 3 trades (60% × 5).
# MAX_SAME_DIRECTION_PCT=60
#
# Minimum IV-RV spread (vol points) required to flag a position as premium-rich.
# Only meaningful when a real options chain is available (proxy IV is suppressed).
# MIN_IV_RV_SPREAD_CREDIT=5.0
#
# Snap-back thresholds: a 5-day move must exceed SNAPBACK_ATR_THRESHOLD × ATR
# AND the 3-day ROC must exceed SNAPBACK_ROC_THRESHOLD % to trigger OVERSOLD_BOUNCE
# or OVERBOUGHT_DROP classification.
# SNAPBACK_ATR_THRESHOLD=2.0
# SNAPBACK_ROC_THRESHOLD=1.0
#
# SPY directional gate: skip bearish signals when SPY 5-day return > +PCT,
# and skip bullish signals when SPY 5-day return < -PCT.
# SPY_DIRECTIONAL_GATE_PCT=1.0

# ─── V2: VIX Circuit Breaker ────────────────────────────────────────────────
# VIX ≥ 28: CAUTION — allow only credit strategies and NEUTRAL direction.
# VIX ≥ 35: DEFENSIVE — neutral-only (iron condors, butterflies, no directional).
# VIX ≥ 45: LIQUIDATION — halt all new trade generation entirely.
# VIX_CAUTION_LEVEL=28
# VIX_DEFENSIVE_LEVEL=35
# VIX_LIQUIDATION_LEVEL=45
#
# VIX spike detection: flag if VIX rises > VIX_SPIKE_THRESHOLD_PCT % above
# its VIX_SPIKE_WINDOW-day rolling average.
# VIX_SPIKE_WINDOW=5
# VIX_SPIKE_THRESHOLD_PCT=25

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

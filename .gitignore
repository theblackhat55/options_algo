# options_algo — .gitignore

# Environment
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Data (raw market data — do not commit; too large)
data/raw/
data/processed/
data/calendar/

# Output (signals, models, trades — machine-generated)
output/signals/
output/models/
output/trades/
output/reports/

# Logs
logs/
*.log

# Testing & Coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Streamlit
.streamlit/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Temporary
tmp/
temp/
scratch/
# Note: .github/ must NOT be ignored — CI workflows live there
